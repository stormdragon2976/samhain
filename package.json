{
  "name": "samhain",
  "description": "Alternative web client for Mastodon",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.0.0 <27",
    "pnpm": ">=11.3.0"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "lint": "eslint .",
    "test": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "5.5.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@sveltejs/kit": "2.68.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "eslint": "10.6.0",
    "eslint-plugin-svelte": "3.20.0",
    "globals": "17.7.0",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "vite": "8.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickColley/samhain.git"
  },
  "keywords": [],
  "author": "Nolan Lawson <nolan@nolanlawson.com>",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/NickColley/samhain/issues"
  },
  "homepage": "https://github.com/NickColley/samhain#readme"
}
